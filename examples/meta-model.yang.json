                "description": "Optional reusable field type and constraint definitions for this entity. Entity fields may reference these by setting type to this name; when type is a definition name, min, max, etc. must not be set inline. Names are unique within this entity only.",
                "x-yang": {
                  "type": "list",
                  "key": "name"
