{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:xframe:meta-model",
  "description": "YANG schema for the xFrame meta-model. This schema validates data model definition files (YAML/JSON) that define entities, fields, and relationships. Foreign keys reference the primary key of the referenced entity by default; optional ``field`` names a different target field that must be marked ``unique`` (alternate key).",
  "x-yang": {
    "module": "meta-model",
    "yang-version": "1.1",
    "namespace": "urn:xframe:meta-model",
    "prefix": "mm",
    "organization": "Exergy LLC",
    "contact": "Exergy.connect@gmail.com"
  },
  "type": "object",
  "properties": {
    "data-model": {
      "type": "object",
      "description": "Root container for data model definition",
      "x-yang": {
        "type": "container"
      },
      "properties": {
        "consolidated": {
          "type": "boolean",
          "description": "",
          "x-yang": {
            "type": "leaf"
          },
          "default": false
        },
        "name": {
          "type": "string",
          "description": "",
          "x-yang": {
            "type": "leaf"
          }
        },
        "version": {
          "type": "string",
          "description": "",
          "x-yang": {
            "type": "leaf"
          }
        },
        "author": {
          "type": "string",
          "description": "",
          "x-yang": {
            "type": "leaf"
          }
        },
        "description": {
          "type": "string",
          "description": "",
          "x-yang": {
            "type": "leaf",
            "mandatory": true
          }
        },
        "source": {
          "type": "string",
          "description": "",
          "x-yang": {
            "type": "leaf"
          }
        },
        "change_history": {
          "type": "string",
          "description": "",
          "x-yang": {
            "type": "leaf"
          },
          "default": "3"
        },
        "include_x_fields": {
          "type": "boolean",
          "description": "",
          "x-yang": {
            "type": "leaf"
          },
          "default": true
        },
        "allow_unlimited_fields": {
          "type": "object",
          "maxProperties": 0,
          "description": "",
          "x-yang": {
            "type": "leaf",
            "must": [
              {
                "must": "count(../entities[count(fields[not(type/array)]) > 7]) > 0",
                "error-message": "allow_unlimited_fields can only be set when at least one entity has more than 7 non-array fields. If all entities have 7 or fewer fields, omit this field.",
                "description": "When this flag is present, at least one entity must exceed the 7-field limit."
              }
            ]
          }
        },
        "max_name_underscores": {
          "type": "integer",
          "minimum": 0,
          "maximum": 255,
          "description": "",
          "x-yang": {
            "type": "leaf"
          },
          "default": 2
        },
        "exclude": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "",
          "x-yang": {
            "type": "leaf-list"
          }
        },
        "entities": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "index": {
                "type": "object",
                "maxProperties": 0,
                "description": "",
                "x-yang": {
                  "type": "leaf",
                  "must": [
                    {
                      "must": "count(../fields[type/foreignKeys[parent_array]]) = 0",
                      "error-message": "index can only be set on top-level entities. Remove index or remove parent_array from this entity's foreignKeys.",
                      "description": "Disallow index on entities that define parent relationships via foreignKeys/parent_array (nested child entities)."
                    }
                  ]
                }
              },
              "name": {
                "type": "string",
                "description": "",
                "x-yang": {
                  "type": "leaf",
                  "must": [
                    {
                      "must": "string-length(.) - string-length(translate(., '_', '')) <= number(/data-model/max_name_underscores)",
                      "error-message": "Entity name exceeds the maximum underscore limit configured in max_name_underscores (default: 2). Deep names suggest missing entity boundaries - create proper entities instead.",
                      "description": "Validates that entity name has at most max_name_underscores underscores (default: 2) to constrain hierarchical depth and reduce parsing complexity."
                    }
                  ],
                  "mandatory": true
                }
              },
              "brief": {
                "type": "string",
                "description": "",
                "x-yang": {
                  "type": "leaf"
                }
              },
              "description": {
                "type": "string",
                "description": "",
                "x-yang": {
                  "type": "leaf",
                  "mandatory": true
                }
              },
              "source": {
                "type": "string",
                "description": "",
                "x-yang": {
                  "type": "leaf"
                }
              },
              "primary_key": {
                "type": "string",
                "description": "",
                "x-yang": {
                  "type": "leafref",
                  "path": "../fields/name",
                  "require-instance": true,
                  "mandatory": true
                }
              },
              "change_history": {
                "type": "string",
                "description": "",
                "x-yang": {
                  "type": "leaf"
                }
              },
              "v": {
                "type": "string",
                "description": "",
                "x-yang": {
                  "type": "leaf"
                }
              },
              "c": {
                "type": "integer",
                "description": "",
                "x-yang": {
                  "type": "leaf",
                  "must": [
                    {
                      "must": "/data-model/consolidated = false() or /data-model/changes[id = current()]",
                      "error-message": "c must reference a valid change ID in the changes list",
                      "description": "c must reference a valid change ID in the changes list. Only enforced during consolidated validation (Phase 2) when change IDs are available."
                    }
                  ]
                }
              },
              "rate_of_change": {
                "type": "string",
                "description": "",
                "x-yang": {
                  "type": "leaf"
                }
              },
              "validation": {
                "type": "string",
                "description": "",
                "x-yang": {
                  "type": "leaf"
                },
                "default": "strict"
              },
              "storage": {
                "type": "string",
                "description": "",
                "x-yang": {
                  "type": "leaf"
                }
              },
              "required_fields": {
                "type": "array",
                "items": {
                  "type": "string",
                  "x-yang": {
                    "type": "leafref",
                    "path": "../fields/name",
                    "require-instance": true
                  }
                },
                "description": "",
                "x-yang": {
                  "type": "leaf-list"
                }
              },
              "m": {
                "type": "array",
                "items": {
                  "type": "integer"
                },
                "description": "",
                "x-yang": {
                  "type": "leaf-list",
                  "must": [
                    {
                      "must": "/data-model/consolidated = false() or /data-model/changes[id = current()]",
                      "error-message": "Each m value must reference a valid change ID in the changes list",
                      "description": "Each m value must reference a valid change ID in the changes list. Only enforced during consolidated validation (Phase 2) when change IDs are available."
                    }
                  ]
                }
              },
              "tools": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "description": "",
                "x-yang": {
                  "type": "leaf-list"
                }
              },
              "field_definitions": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "name": {
                      "type": "string",
                      "description": "",
                      "x-yang": {
                        "type": "leaf",
                        "mandatory": true
                      }
                    },
                    "brief": {
                      "type": "string",
                      "description": "",
                      "x-yang": {
                        "type": "leaf"
                      }
                    },
                    "description": {
                      "type": "string",
                      "description": "",
                      "x-yang": {
                        "type": "leaf",
                        "mandatory": true
                      }
                    },
                    "source": {
                      "type": "string",
                      "description": "",
                      "x-yang": {
                        "type": "leaf"
                      }
                    },
                    "required": {
                      "type": "boolean",
                      "description": "",
                      "x-yang": {
                        "type": "leaf",
                        "must": [
                          {
                            "must": "not(../default) or . = false()",
                            "error-message": "A required field cannot have a default value. If required is true, default must not be specified.",
                            "description": "A required field cannot have a default value."
                          }
                        ]
                      },
                      "default": false
                    },
                    "default": {
                      "oneOf": [
                        {
                          "type": "string"
                        },
                        {
                          "type": "integer"
                        },
                        {
                          "type": "number",
                          "multipleOf": 0.010000000000000002,
                          "x-yang": {
                            "type": "decimal64",
                            "fraction-digits": 2
                          }
                        },
                        {
                          "type": "boolean"
                        }
                      ],
                      "description": "",
                      "x-yang": {
                        "type": "leaf",
                        "when": {
                          "condition": "boolean(../type/primitive) or boolean(../type/enum)"
                        }
                      }
                    },
                    "unique": {
                      "type": "boolean",
                      "description": "",
                      "x-yang": {
                        "type": "leaf",
                        "when": {
                          "condition": "not(../default)"
                        }
                      },
                      "default": false
                    },
                    "validation": {
                      "type": "string",
                      "description": "",
                      "x-yang": {
                        "type": "leaf"
                      },
                      "default": "enforce"
                    },
                    "type": {
                      "type": "object",
                      "description": "Field type: primitive, array or composite.",
                      "x-yang": {
                        "type": "container"
                      },
                      "properties": {
                        "foreignKeys": {
                          "type": "array",
                          "items": {
                            "type": "object",
                            "properties": {
                              "entity": {
                                "type": "string",
                                "description": "",
                                "x-yang": {
                                  "type": "leafref",
                                  "path": "/data-model/entities/name",
                                  "require-instance": true,
                                  "mandatory": true
                                }
                              },
                              "field": {
                                "type": "string",
                                "description": "",
                                "x-yang": {
                                  "type": "leafref",
                                  "path": "/data-model/entities[name = current()/../entity]/fields/name",
                                  "require-instance": true,
                                  "must": [
                                    {
                                      "must": "/data-model/consolidated = false() or string(.) != string(/data-model/entities[name = string(deref(../entity))]/primary_key)",
                                      "error-message": "field must not name the referenced entity's primary key; omit field to reference the primary key.",
                                      "description": "When present, field must differ from the target entity's primary_key. Entity key via deref(../entity). Skipped when consolidated is false."
                                    },
                                    {
                                      "must": "/data-model/consolidated = false() or boolean(deref(.)/../unique) = true()",
                                      "error-message": "field must name a field on the referenced entity with unique true (alternate key). Set unique: true on that field in the model.",
                                      "description": "Non-primary foreign key targets must be explicitly marked unique: follow this leafref with deref(.) to fields/name, then sibling ../unique. Skipped when consolidated is false."
                                    }
                                  ]
                                }
                              },
                              "parent_array": {
                                "type": "string",
                                "description": "",
                                "x-yang": {
                                  "type": "leafref",
                                  "path": "/data-model/entities/fields/name",
                                  "require-instance": true,
                                  "must": [
                                    {
                                      "must": "/data-model/consolidated = false() or count(/data-model/entities[name = string(deref(../entity))]/fields[name = current()]/type/array) = 1",
                                      "error-message": "parent_array must name a field on the referenced entity whose type uses the array branch directly (not via field_definitions); skipped when consolidated is false.",
                                      "description": "Requires a direct type/array container on the referenced field. Fields that only reference field_definitions are not checked here. Skipped when consolidated is false."
                                    }
                                  ]
                                }
                              }
                            },
                            "additionalProperties": false,
                            "required": [
                              "entity"
                            ]
                          },
                          "description": "Each entry points at an entity; values align with primary key unless ``field`` specifies another target field (which must be marked ``unique`` on the referenced entity).",
                          "x-yang": {
                            "type": "list",
                            "key": "entity"
                          },
                          "minItems": 1
                        },
                        "choice-type": {
                          "type": "object",
                          "description": "",
                          "x-yang": {
                            "type": "choice",
                            "mandatory": true
                          },
                          "oneOf": [
                            {
                              "type": "object",
                              "description": "",
                              "properties": {
                                "definition": {
                                  "type": "string",
                                  "x-yang": {
                                    "type": "leaf"
                                  }
                                }
                              },
                              "additionalProperties": false,
                              "required": [
                                "definition"
                              ],
                              "x-yang": {
                                "name": "definition"
                              }
                            },
                            {
                              "type": "object",
                              "description": "",
                              "properties": {
                              },
                              "additionalProperties": false,
                              "required": [
                              ],
                              "x-yang": {
                                "name": "open-type"
                              }
                            },
                            {
                              "type": "object",
                              "description": "",
                              "properties": {
                              },
                              "additionalProperties": false,
                              "required": [
                              ],
                              "x-yang": {
                                "name": "entity-type"
                              }
                            },
                            {
                              "type": "object",
                              "description": "",
                              "properties": {
                                "array": {
                                  "type": "string",
                                  "x-yang": {
                                    "type": "leaf"
                                  }
                                }
                              },
                              "additionalProperties": false,
                              "required": [
                                "array"
                              ],
                              "x-yang": {
                                "name": "case-array"
                              }
                            },
                            {
                              "type": "object",
                              "description": "",
                              "properties": {
                              },
                              "additionalProperties": false,
                              "required": [
                              ],
                              "x-yang": {
                                "name": "case-composite"
                              }
                            }
                          ]
                        }
                      },
                      "additionalProperties": false
                    },
                    "computed": {
                      "type": "object",
                      "description": "When present, the field value is derived from referenced fields using the given operation.\n         Computed fields are read-only in JSON Schema and excluded from required_fields.",
                      "x-yang": {
                        "type": "container"
                      },
                      "properties": {
                        "operation": {
                          "type": "string",
                          "enum": [
                            "add",
                            "subtraction",
                            "multiplication",
                            "division",
                            "min",
                            "max",
                            "average"
                          ],
                          "description": "",
                          "x-yang": {
                            "type": "leaf",
                            "mandatory": true
                          }
                        },
                        "fields": {
                          "type": "array",
                          "items": {
                            "type": "object",
                            "properties": {
                              "field": {
                                "type": "string",
                                "description": "",
                                "x-yang": {
                                  "type": "leaf",
                                  "must": [
                                    {
                                      "must": "/data-model/consolidated = false() or ((not(../entity) and count(../../../../fields[name = current()]) = 1) or (../entity and count(deref(../entity)/../fields[name = current()]) = 1))",
                                      "error-message": "Computed field reference must exist in the specified entity (or current entity if not specified)",
                                      "description": "Validates that the field exists: in current entity when entity is omitted, or in referenced entity when entity is specified. Only enforced during consolidated validation (Phase 2) when cross-file references can be resolved."
                                    }
                                  ],
                                  "mandatory": true
                                }
                              },
                              "entity": {
                                "type": "string",
                                "description": "",
                                "x-yang": {
                                  "type": "leafref",
                                  "path": "/data-model/entities/name",
                                  "require-instance": true,
                                  "must": [
                                    {
                                      "must": "/data-model/consolidated = false() or count(../../../../fields[type/foreignKeys/entity = current()]) = 1",
                                      "error-message": "Cross-entity computed field references require a foreign key field in the current entity that references the target entity",
                                      "description": "When entity is specified, there must be exactly one field in the current entity with a foreignKeys referencing this entity. Only enforced during consolidated validation (Phase 2) when cross-file references can be resolved."
                                    }
                                  ]
                                }
                              }
                            },
                            "additionalProperties": false,
                            "required": [
                              "field"
                            ]
                          },
                          "description": "Field references for the computation (same entity or cross-entity with entity leaf).",
                          "x-yang": {
                            "type": "list",
                            "key": "field"
                          },
                          "minItems": 2,
                          "maxItems": 100
                        }
                      },
                      "additionalProperties": false,
                      "required": [
                        "operation"
                      ]
                    }
